<?xml version="1.0" encoding="utf-8"?>
<!-- 
    INSTRUÇÃO: Para usar a fonte Cinzel, baixe em:
    https://fonts.google.com/specimen/Cinzel
    
    Salve os arquivos:
    - Cinzel-Bold.ttf  → app/src/main/res/font/cinzel_bold.ttf
    - Cinzel-Regular.ttf → app/src/main/res/font/cinzel_regular.ttf
    
    Enquanto não faz isso, o app usa a fonte padrão do Android.
    No layout da Splash, o atributo android:fontFamily="@font/cinzel_bold"
    pode ser substituído temporariamente por android:fontFamily="serif"
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        app:fontStyle="normal"
        app:fontWeight="700"
        app:font="@font/cinzel_bold"/>
</font-family>
