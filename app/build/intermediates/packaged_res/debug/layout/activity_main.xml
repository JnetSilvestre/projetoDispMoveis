<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy_dark"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="VersU"
            app:titleTextColor="@color/gold_light"
            app:contentInsetStart="20dp"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Filtre por categoria ou sorteie aleatoriamente"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="14dp"/>

            <!-- Chips de filtro -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="22dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_categorias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"/>

            </HorizontalScrollView>

            <!-- Card do versículo -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_versiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardElevation="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Cabeçalho do card: ornamento + btn favorito -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_reading"
                            app:tint="@color/gold_light"
                            android:alpha="0.4"
                            android:contentDescription="@string/desc_icone_leitura"/>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>

                        <ImageButton
                            android:id="@+id/btn_favorito"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/btn_star_big_off"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/favoritar"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- Placeholder inicial -->
                    <TextView
                        android:id="@+id/tv_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Toque em Sortear Versículo\npara receber uma promessa bíblica"
                        android:textSize="16sp"
                        android:textColor="@color/text_placeholder"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.6"
                        android:paddingVertical="24dp"/>

                    <!-- Texto do versículo -->
                    <TextView
                        android:id="@+id/tv_texto_versiculo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.7"
                        android:gravity="center"
                        android:visibility="gone"/>

                    <!-- Divisor dourado -->
                    <View
                        android:id="@+id/view_divider"
                        android:layout_width="48dp"
                        android:layout_height="2dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@color/gold_light"
                        android:alpha="0.6"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"/>

                    <!-- Referência bíblica -->
                    <TextView
                        android:id="@+id/tv_referencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/gold_light"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <!-- Chip de categoria do versículo sorteado -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_categoria_versiculo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:clickable="false"
                        android:focusable="false"
                        app:chipBackgroundColor="@color/gold_light_alpha"
                        app:chipStrokeColor="@color/gold_light"
                        app:chipStrokeWidth="1dp"
                        android:textColor="@color/gold_light"
                        android:textSize="12sp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botão sortear -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sortear"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_sortear"
                app:icon="@drawable/ic_reading"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="20dp"
                app:iconTint="@color/navy_dark"
                android:textSize="17sp"
                android:textColor="@color/navy_dark"
                android:letterSpacing="0.03"
                app:backgroundTint="@color/gold_light"
                app:cornerRadius="30dp"
                app:elevation="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/versiculos_count"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="12dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
