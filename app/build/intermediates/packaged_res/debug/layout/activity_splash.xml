<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_darkest">

    <ImageView
        android:id="@+id/img_logo_splash"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_versu_logo"
        android:contentDescription="Logo VersU"
        app:layout_constraintBottom_toTopOf="@id/tv_app_name_splash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_app_name_splash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VersU"
        android:textSize="58sp"
        android:textColor="@color/gold_light"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.1"
        app:layout_constraintBottom_toTopOf="@id/tv_slogan_splash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/img_logo_splash"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_slogan_splash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sua caixinha de promessas digital"
        android:textSize="15sp"
        android:textColor="@color/white_alpha_70"
        android:letterSpacing="0.04"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_app_name_splash"
        app:layout_constraintVertical_bias="0.05"/>

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_iasd_logo"
        android:alpha="0.25"
        android:contentDescription="@string/desc_simbolo_igreja"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="32dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
